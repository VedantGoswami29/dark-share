<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - File Sharing Network</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    <nav class="bg-slate-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <!-- Brand -->
                <a href="/" class="flex items-center space-x-2 text-white font-bold text-xl">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
                    </svg>
                    <span>File Sharing Network</span>
                </a>

                <!-- Desktop nav -->
                <div class="hidden md:flex items-center space-x-4">
                    <a href="/active-users" class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">
                        Active Users
                    </a>
                    <a href="/qrcode" class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">
                        QR Code
                    </a>
                </div>

                <!-- Mobile toggle -->
                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="text-gray-300 hover:text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-menu" class="md:hidden hidden pb-3">
                <a href="/active-users" class="block text-gray-300 hover:text-white px-3 py-2 rounded-md">Active Users</a>
                <a href="/qrcode" class="block text-gray-300 hover:text-white px-3 py-2 rounded-md">QR Code</a>
            </div>
        </div>
    </nav>

    <main class="flex-1">
        <%- body %>
    </main>

    <footer class="bg-slate-800 text-white py-4">
        <p class="text-center text-sm text-gray-400">File Sharing Network — Share files across devices</p>
    </footer>

    <script src="/public/script.js"></script>
</body>
</html>
