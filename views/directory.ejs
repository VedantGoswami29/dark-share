<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 flex items-center mb-1">
            <svg class="w-8 h-8 inline-block mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
            </svg>
            <%= currentPath %>
        </h1>
        <p class="text-gray-500 text-sm">Browse and manage files</p>
    </div>

    <!-- Error -->
    <% if (error) { %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 flex items-center">
            <svg class="w-5 h-5 text-red-400 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-red-800 font-medium"><%= error %></p>
        </div>
    <% } %>

    <!-- Upload Form -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Upload to: <span class="text-blue-600"><%= currentPath %></span></h2>

        <div id="upload-progress" class="hidden mb-4">
            <div class="flex justify-between text-sm text-gray-600 mb-1">
                <span>Uploading...</span>
                <span id="progress-percent">0%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
                <div id="progress-bar" class="bg-blue-600 h-2 rounded-full" style="width:0%"></div>
            </div>
        </div>

        <div id="upload-message" class="hidden mb-4"></div>

        <form id="upload-form" action="/upload" method="post" enctype="multipart/form-data" class="space-y-4">
            <input type="hidden" name="currentPath" value="<%= currentPath %>">

            <div id="file-preview" class="hidden space-y-2"></div>

            <label for="file" id="upload-area"
                   class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-300
                          rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 file-upload-area">
                <svg class="w-8 h-8 mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
                <p class="text-sm text-gray-500"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                <p class="text-xs text-gray-400 mt-1">Any file type supported</p>
                <input id="file" name="files" type="file" class="hidden" multiple>
            </label>

            <button type="submit" id="upload-btn" disabled
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700
                           transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed">
                <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
                Upload File
            </button>
        </form>
    </div>

    <!-- Search & Sort -->
    <div class="bg-white rounded-lg shadow-md p-4 mb-6 flex flex-col md:flex-row items-center gap-4">
        <form action="<%= currentPath %>" method="GET" class="w-full md:flex-1">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" name="q" value="<%= searchQuery || '' %>"
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md text-sm
                              focus:outline-none focus:ring-1 focus:ring-blue-500"
                       placeholder="Search files and folders...">
                <% if (sortBy && sortOrder) { %>
                    <input type="hidden" name="sortBy" value="<%= sortBy %>">
                    <input type="hidden" name="sortOrder" value="<%= sortOrder %>">
                <% } %>
            </div>
        </form>

        <div class="flex items-center space-x-2 flex-shrink-0">
            <span class="text-sm text-gray-500 hidden sm:block">Sort:</span>
            <% ['name', 'size', 'date'].forEach(key => {
                const active = sortBy === key;
                const nextOrder = (active && sortOrder === 'asc') ? 'desc' : 'asc';
                let href = `${currentPath}?sortBy=${key}&sortOrder=${nextOrder}`;
                if (searchQuery) href += `&q=${encodeURIComponent(searchQuery)}`;
            %>
                <a href="<%= href %>"
                   class="px-3 py-1.5 rounded-md text-sm font-medium
                          <%= active ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                    <%= key.charAt(0).toUpperCase() + key.slice(1) %>
                    <% if (active) { %>
                        <svg class="w-3 h-3 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="<%= sortOrder === 'asc' ? 'M5 15l7-7 7 7' : 'M19 9l-7 7-7-7' %>"/>
                        </svg>
                    <% } %>
                </a>
            <% }); %>
        </div>
    </div>

    <!-- File Listing -->
    <% if (files && files.length > 0) { %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                <h2 class="text-xl font-semibold text-gray-900">Files &amp; Folders</h2>
            </div>

            <% if (currentPath !== '/' && parentPath) { %>
                <div class="px-6 py-3 border-b border-gray-100">
                    <a href="<%= parentPath %>" class="text-blue-600 hover:text-blue-800 flex items-center text-sm">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Parent directory
                    </a>
                </div>
            <% } %>

            <div class="p-6">
                <!-- Mobile list -->
                <div class="block lg:hidden space-y-3">
                    <% files.forEach(file => { %>
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 flex items-center justify-between">
                            <div class="flex items-center space-x-3 flex-1 min-w-0">
                                <% if (file.isDirectory) { %>
                                    <svg class="w-6 h-6 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
                                    </svg>
                                <% } else { %>
                                    <%- include('partials/file-icon', { fileName: file.name, currentPath, size: 'small' }) %>
                                <% } %>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-gray-900 truncate"><%= file.name %><%= file.isDirectory ? '/' : '' %></p>
                                    <p class="text-xs text-gray-500">
                                        <% if (!file.isDirectory && file.size) { %><%= formatFileSize(file.size) %> &bull; <% } %>
                                        <%= file.lastModified %>
                                    </p>
                                </div>
                            </div>
                            <div class="flex space-x-2 ml-2 flex-shrink-0">
                                <% if (file.isDirectory) { %>
                                    <a href="<%= file.path %>" class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">Open</a>
                                <% } else { %>
                                    <a href="/files<%= file.path %>" class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">View</a>
                                    <a href="/download/<%= encodeURIComponent(file.name) %>?path=<%= encodeURIComponent(currentPath) %>"
                                       class="bg-gray-600 text-white px-3 py-1 rounded text-sm hover:bg-gray-700">↓</a>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <!-- Desktop grid -->
                <div class="hidden lg:grid grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-6">
                    <% files.forEach(file => { %>
                        <div class="bg-white rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col">
                            <div class="p-6 flex-grow flex flex-col items-center">
                                <div class="flex items-center justify-center w-16 h-16 mb-4 rounded-lg
                                            <%= file.isDirectory ? 'bg-blue-50' : 'bg-gray-50' %>">
                                    <% if (file.isDirectory) { %>
                                        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
                                        </svg>
                                    <% } else { %>
                                        <%- include('partials/file-icon', { fileName: file.name, currentPath, size: 'large' }) %>
                                    <% } %>
                                </div>
                                <h3 class="text-sm font-medium text-gray-900 text-center truncate w-full" title="<%= file.name %>">
                                    <%= file.name %><%= file.isDirectory ? '/' : '' %>
                                </h3>
                                <p class="text-xs text-gray-400 mt-1 text-center">
                                    <% if (!file.isDirectory && file.size) { %><%= formatFileSize(file.size) %><br><% } %>
                                    <%= file.lastModified %>
                                </p>
                            </div>
                            <div class="p-4 bg-gray-50 border-t border-gray-100 space-y-2">
                                <% if (file.isDirectory) { %>
                                    <a href="<%= file.path %>"
                                       class="block w-full text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 text-sm font-medium">
                                        Open Folder
                                    </a>
                                <% } else { %>
                                    <a href="/files<%= file.path %>"
                                       class="block w-full text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 text-sm font-medium">
                                        View
                                    </a>
                                    <a href="/download/<%= encodeURIComponent(file.name) %>?path=<%= encodeURIComponent(currentPath) %>"
                                       class="block w-full text-center bg-gray-600 text-white py-2 rounded-lg hover:bg-gray-700 text-sm font-medium">
                                        Download
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>

    <% } else if (!error) { %>
        <div class="bg-white rounded-lg shadow-md p-12 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <% if (searchQuery) { %>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                <% } else { %>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"/>
                <% } %>
            </svg>
            <% if (searchQuery) { %>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No results for "<%= searchQuery %>"</h3>
                <a href="<%= currentPath %>" class="text-blue-600 hover:underline text-sm">Clear search</a>
            <% } else { %>
                <h3 class="text-lg font-medium text-gray-900 mb-2">This directory is empty</h3>
                <p class="text-gray-500 text-sm">Upload a file to get started</p>
            <% } %>
        </div>
    <% } %>
</div>
